{
  "suite": "permission_matching",
  "description": "Tests for matchPermission(granted, required) -> boolean",
  "cases": [
    { "name": "exact_match", "granted": "files:documents:read", "required": "files:documents:read", "expected": true },
    { "name": "exact_mismatch_action", "granted": "files:documents:read", "required": "files:documents:write", "expected": false },
    { "name": "exact_mismatch_resource", "granted": "files:documents:read", "required": "files:storage:read", "expected": false },
    { "name": "exact_mismatch_service", "granted": "files:documents:read", "required": "billing:documents:read", "expected": false },
    { "name": "wildcard_service", "granted": "*:documents:read", "required": "files:documents:read", "expected": true },
    { "name": "wildcard_resource", "granted": "files:*:read", "required": "files:documents:read", "expected": true },
    { "name": "wildcard_resource_alt", "granted": "files:*:read", "required": "files:storage:read", "expected": true },
    { "name": "wildcard_action", "granted": "files:documents:*", "required": "files:documents:read", "expected": true },
    { "name": "wildcard_action_write", "granted": "files:documents:*", "required": "files:documents:write", "expected": true },
    { "name": "wildcard_action_delete", "granted": "files:documents:*", "required": "files:documents:delete", "expected": true },
    { "name": "full_wildcard_1", "granted": "*:*:*", "required": "files:documents:read", "expected": true },
    { "name": "full_wildcard_2", "granted": "*:*:*", "required": "billing:invoices:write", "expected": true },
    { "name": "full_wildcard_3", "granted": "*:*:*", "required": "workflow:instances:execute", "expected": true },
    { "name": "double_wildcard_1", "granted": "files:*:*", "required": "files:documents:read", "expected": true },
    { "name": "double_wildcard_2", "granted": "*:documents:*", "required": "files:documents:write", "expected": true },
    { "name": "double_wildcard_3", "granted": "*:*:read", "required": "files:documents:read", "expected": true },
    { "name": "wildcard_mismatch_service", "granted": "files:*:read", "required": "billing:invoices:read", "expected": false },
    { "name": "wildcard_mismatch_resource", "granted": "files:documents:*", "required": "files:storage:read", "expected": false },
    { "name": "wildcard_mismatch_action", "granted": "*:*:read", "required": "files:documents:write", "expected": false },
    { "name": "non_standard_format_match", "granted": "simple", "required": "simple", "expected": true },
    { "name": "non_standard_format_mismatch", "granted": "simple", "required": "other", "expected": false },
    { "name": "two_segment_no_match", "granted": "files:read", "required": "files:documents:read", "expected": false },
    { "name": "four_segment_no_match", "granted": "a:b:c:d", "required": "a:b:c:d", "expected": true },
    { "name": "empty_strings", "granted": "", "required": "", "expected": true },
    { "name": "empty_vs_value", "granted": "", "required": "files:documents:read", "expected": false }
  ]
}
