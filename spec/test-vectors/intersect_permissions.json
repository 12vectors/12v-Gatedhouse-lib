{
  "suite": "intersect_permissions",
  "description": "Tests for intersectPermissions(setA, setB) -> resultSet. Order within result does not matter; compare as sets.",
  "cases": [
    {
      "name": "exact_overlap",
      "set_a": ["files:documents:read", "files:documents:write"],
      "set_b": ["files:documents:write", "billing:invoices:read"],
      "expected_contains": ["files:documents:write"],
      "expected_not_contains": ["files:documents:read", "billing:invoices:read"]
    },
    {
      "name": "wildcard_narrows_to_specific",
      "set_a": ["files:*:*"],
      "set_b": ["files:documents:read", "billing:invoices:read"],
      "expected_contains": ["files:documents:read"],
      "expected_not_contains": ["billing:invoices:read"]
    },
    {
      "name": "disjoint_sets",
      "set_a": ["files:documents:read"],
      "set_b": ["billing:invoices:write"],
      "expected_contains": [],
      "expected_not_contains": ["files:documents:read", "billing:invoices:write"]
    },
    {
      "name": "empty_set_a",
      "set_a": [],
      "set_b": ["files:documents:read"],
      "expected_contains": [],
      "expected_not_contains": ["files:documents:read"]
    },
    {
      "name": "empty_set_b",
      "set_a": ["files:documents:read"],
      "set_b": [],
      "expected_contains": [],
      "expected_not_contains": ["files:documents:read"]
    },
    {
      "name": "superadmin_intersect",
      "set_a": ["*:*:*"],
      "set_b": ["files:documents:read", "billing:invoices:write"],
      "expected_contains": ["files:documents:read", "billing:invoices:write"],
      "expected_not_contains": []
    }
  ]
}
