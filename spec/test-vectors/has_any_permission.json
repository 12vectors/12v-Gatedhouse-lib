{
  "suite": "has_any_permissions",
  "description": "Tests for hasAnyPermission(grantedSet, requiredList) -> boolean",
  "cases": [
    {
      "name": "first_matches",
      "granted_set": ["files:documents:read"],
      "required": ["files:documents:read", "files:documents:write"],
      "expected": true
    },
    {
      "name": "second_matches",
      "granted_set": ["files:documents:write"],
      "required": ["files:documents:read", "files:documents:write"],
      "expected": true
    },
    {
      "name": "none_match",
      "granted_set": ["billing:invoices:read"],
      "required": ["files:documents:read", "files:documents:write"],
      "expected": false
    },
    {
      "name": "empty_required",
      "granted_set": ["files:documents:read"],
      "required": [],
      "expected": false
    },
    {
      "name": "wildcard_matches_one",
      "granted_set": ["files:*:read"],
      "required": ["billing:invoices:write", "files:storage:read"],
      "expected": true
    }
  ]
}
