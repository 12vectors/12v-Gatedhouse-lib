{
  "suite": "has_permission",
  "description": "Tests for hasPermission(grantedSet, required) -> boolean",
  "cases": [
    {
      "name": "exact_in_set",
      "granted_set": ["files:documents:read", "files:documents:write"],
      "required": "files:documents:read",
      "expected": true
    },
    {
      "name": "wildcard_in_set",
      "granted_set": ["files:*:read", "billing:invoices:write"],
      "required": "files:documents:read",
      "expected": true
    },
    {
      "name": "no_match_in_set",
      "granted_set": ["files:documents:read"],
      "required": "files:documents:delete",
      "expected": false
    },
    {
      "name": "empty_set",
      "granted_set": [],
      "required": "files:documents:read",
      "expected": false
    },
    {
      "name": "superadmin_in_set",
      "granted_set": ["*:*:*"],
      "required": "anything:at:all",
      "expected": true
    },
    {
      "name": "multiple_wildcards_first_matches",
      "granted_set": ["billing:*:read", "files:*:*"],
      "required": "files:documents:delete",
      "expected": true
    }
  ]
}
