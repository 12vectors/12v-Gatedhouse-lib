{
  "citadel_events": [
    { "type": "org.created", "description": "New organization created — seed base roles" },
    { "type": "org.deleted", "description": "Organization deleted — purge all authorization data" },
    { "type": "org.suspended", "description": "Organization suspended — suspend all memberships" },
    { "type": "org.reactivated", "description": "Organization reactivated — restore memberships" },
    { "type": "membership.created", "description": "New membership — cache and assign default role" },
    { "type": "membership.updated", "description": "Membership updated — update cache, rebuild permissions" },
    { "type": "membership.suspended", "description": "Membership suspended — all checks fail" },
    { "type": "membership.reactivated", "description": "Membership reactivated — restore permissions" },
    { "type": "membership.removed", "description": "Membership removed — purge cache and assignments" },
    { "type": "group.member.added", "description": "Member added to group — inherit group roles" },
    { "type": "group.member.removed", "description": "Member removed from group — remove group roles" },
    { "type": "group.deleted", "description": "Group deleted — remove from all caches, rebuild permissions" }
  ],
  "sphinx_events": [
    { "type": "delegation.created", "description": "New delegation — insert into delegation cache" },
    { "type": "delegation.revoked", "description": "Delegation revoked — mark as revoked" },
    { "type": "delegation.expired", "description": "Delegation expired — mark as expired" },
    { "type": "delegation.exhausted", "description": "Delegation uses exhausted — mark as exhausted" },
    { "type": "agent.deactivated", "description": "Agent deactivated — revoke all delegations" }
  ],
  "audit_events": [
    { "type": "authz.decision.allowed", "description": "Authorization check allowed" },
    { "type": "authz.decision.denied", "description": "Authorization check denied" }
  ]
}
