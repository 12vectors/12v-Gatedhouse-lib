{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://superagent.dev/schemas/gatedhouse/events.json",
  "title": "GatehouseEvents",
  "description": "Event types consumed and produced by Gatedhouse",
  "type": "object",
  "properties": {
    "citadel_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/event_type_def" }
    },
    "sphinx_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/event_type_def" }
    },
    "audit_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/event_type_def" }
    }
  },
  "$defs": {
    "event_type_def": {
      "type": "object",
      "required": ["type", "description", "fields"],
      "properties": {
        "type": { "type": "string" },
        "description": { "type": "string" },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "required": { "type": "boolean" },
              "description": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
