{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://superagent.dev/schemas/gatedhouse/config.json",
  "title": "GatehouseConfig",
  "description": "Configuration for Gatedhouse library initialization",
  "type": "object",
  "required": ["jwks_url", "database", "service"],
  "properties": {
    "jwks_url": {
      "type": "string",
      "format": "uri",
      "description": "Sphinx JWKS endpoint for JWT verification"
    },
    "jwks_cache_ttl": {
      "type": "integer",
      "default": 3600,
      "description": "JWKS cache TTL in seconds"
    },
    "database": {
      "type": "object",
      "required": ["connection_string"],
      "properties": {
        "connection_string": { "type": "string" },
        "migrations_table": { "type": "string", "default": "gatedhouse_migrations" },
        "table_prefix": { "type": "string", "default": "gatedhouse_" },
        "pool_min": { "type": "integer", "default": 2 },
        "pool_max": { "type": "integer", "default": 10 }
      }
    },
    "event_bus": {
      "type": "object",
      "properties": {
        "adapter": { "type": "string", "enum": ["kafka", "rabbitmq", "in_memory", "noop"], "default": "noop" },
        "topics": { "type": "array", "items": { "type": "string" } }
      }
    },
    "service": {
      "type": "string",
      "description": "Service identity used in permission keys"
    },
    "org_header": { "type": "string", "default": "X-Org-Id" },
    "org_required": { "type": "boolean", "default": true },
    "cache_miss_strategy": { "type": "string", "enum": ["fetch", "deny"], "default": "fetch" },
    "cache_miss_ttl": { "type": "integer", "default": 60 },
    "resolved_permissions_cache_ttl": { "type": "integer", "default": 300 },
    "audit": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "log_denied": { "type": "boolean", "default": true },
        "log_allowed": { "type": "boolean", "default": false }
      }
    },
    "default_role": { "type": "string", "default": "member" },
    "citadel_base_url": { "type": "string", "format": "uri" },
    "delegation": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "cache_ttl": { "type": "integer", "default": 60 },
        "validate_live": { "type": "boolean", "default": false },
        "allowed_identity_types": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["human", "agent", "machine"]
        }
      }
    }
  }
}
