{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://superagent.dev/schemas/gatedhouse/delegation.json",
  "title": "DelegationContext",
  "description": "Delegation context for agent requests acting on behalf of a person",
  "type": "object",
  "required": ["id", "delegator_id", "delegator_membership_id", "scopes", "constraints", "expires_at"],
  "properties": {
    "id": {
      "type": "string",
      "description": "dlg_{ulid}"
    },
    "delegator_id": {
      "type": "string",
      "description": "per_{ulid} of the person who granted authority"
    },
    "delegator_membership_id": {
      "type": "string",
      "description": "mbr_{ulid} of the delegator in this org"
    },
    "scopes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Permission scopes granted by the delegation"
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true,
      "description": "Delegation constraints (arbitrary key-value)"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "uses_remaining": {
      "type": "integer",
      "minimum": 0,
      "description": "Remaining uses (null/absent = unlimited)"
    }
  }
}
