{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://superagent.dev/schemas/gatedhouse/membership.json",
  "title": "MembershipContext",
  "description": "The identity's membership in an organization",
  "type": "object",
  "required": ["id", "entity_type", "is_owner", "status", "groups"],
  "properties": {
    "id": {
      "type": "string",
      "description": "mbr_{ulid}"
    },
    "entity_type": {
      "$ref": "#/$defs/entity_type"
    },
    "is_owner": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": ["active", "suspended", "invited"]
    },
    "groups": {
      "type": "array",
      "items": { "type": "string" },
      "description": "grp_{ulid}[]"
    }
  },
  "$defs": {
    "entity_type": {
      "type": "string",
      "enum": ["person", "agent", "service_account"]
    }
  }
}
